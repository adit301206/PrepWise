# --- Supabase & Secrets ---
# Crucial: Ignore your actual keys
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Supabase CLI local development files
# If you run 'supabase init', it creates a 'supabase' folder
supabase/.branches/
supabase/.temp/
supabase/storage/
# DO NOT ignore supabase/config.toml if you want to share schema config, 
# but DO ignore it if you hardcode secrets there (not recommended).

# --- Databases (Backup) ---
*.db
*.sqlite3

